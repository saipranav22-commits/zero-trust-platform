# Environment variables for Zero Trust Platform
# Copy this file to .env and fill in your values

# ─── Gemini AI ────────────────────────────────────────────────
# Set to true to enable AI-powered security assistant
GEMINI_AI_ENABLED=false

# Your Google Gemini API key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=

# ─── Database ─────────────────────────────────────────────────
# Override if running without Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zerotrust_db
POSTGRES_USER=zerotrust
POSTGRES_PASSWORD=zerotrust123

# ─── JWT ──────────────────────────────────────────────────────
# Must be at least 32 chars for HS256 security — change in production!
JWT_SECRET=zerotrust-platform-super-secret-key-for-hs256-algorithm-must-be-at-least-256-bits
