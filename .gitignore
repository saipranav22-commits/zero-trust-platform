application-local.yml
application-prod.yml

# ─── Node / React ──────────────────────────
node_modules/
dist/
.vite/
*.local

# ─── Environment ───────────────────────────
.env
.env.local
.env.production

# ─── IDE ───────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo

# ─── OS ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

